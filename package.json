{
  "name": "backend-assessment",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start:user": "nest start user-service",
    "start:wallet": "nest start wallet-service",
    "start:user:prod": "node dist/apps/user-service/main.js",
    "start:wallet:prod": "node dist/apps/wallet-service/main.js",
    "start:user:dev": "nest start user-service --watch",
    "start:wallet:dev": "nest start wallet-service --watch",
    "build": "npm run generate && nest build user-service && nest build wallet-service",
    "build:user": "npm run generate && nest build user-service",
    "build:wallet": "npm run generate && nest build wallet-service",
    "migrate": "./node_modules/.bin/prisma migrate dev --schema=packages/prisma/schema.prisma",
    "migrate:deploy": "./node_modules/.bin/prisma migrate deploy --schema=packages/prisma/schema.prisma",
    "generate": "./node_modules/.bin/prisma generate --schema=packages/prisma/schema.prisma",
    "db:push": "./node_modules/.bin/prisma db push --schema=packages/prisma/schema.prisma",
    "db:studio": "./node_modules/.bin/prisma studio --schema=packages/prisma/schema.prisma"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.10.6",
    "@grpc/proto-loader": "^0.7.13",
    "@nestjs/common": "^10.3.8",
    "@nestjs/core": "^10.3.8",
    "@nestjs/microservices": "^10.3.8",
    "@prisma/client": "5.11.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "nestjs-pino": "^4.1.0",
    "pino-http": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "prisma": "5.11.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.2",
    "@nestjs/schematics": "^10.1.1",
    "@types/node": "^20.12.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
