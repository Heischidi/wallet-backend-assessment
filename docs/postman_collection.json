  "info": {
    "_postman_id": "4e738aa1-d922-4916-8316-ff26ddbcfa7f",
    "name": "Wallet System gRPC",
    "description": "gRPC API collection for the Wallet & User microservices. \n\n**Note for Postman:** Since this is a gRPC system, make sure to create a **New > gRPC Request** in Postman, enter the server URL (`localhost:5001` for User, `localhost:5002` for Wallet), and import the `.proto` files located in the `packages/proto` directory for automatic autocomplete and structure mapping.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "User Service",
      "item": [
        {
          "name": "1. Create User",
          "request": {
            "method": "INVOKE",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"test@example.com\",\n    \"name\": \"Jane Doe\"\n}"
            },
            "url": {
              "raw": "localhost:5001/user.UserService/CreateUser",
              "host": ["localhost"],
              "port": "5001",
              "path": ["user.UserService", "CreateUser"]
            },
            "description": "Requires importing `packages/proto/user.proto` into your Postman gRPC API definition."
          },
          "response": []
        },
        {
          "name": "2. Get User By Id",
          "request": {
            "method": "INVOKE",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"id\": \"<INSERT_USER_ID_HERE>\"\n}"
            },
            "url": {
              "raw": "localhost:5001/user.UserService/GetUserById",
              "host": ["localhost"],
              "port": "5001",
              "path": ["user.UserService", "GetUserById"]
            }
          },
          "response": []
        }
      ]
    },
